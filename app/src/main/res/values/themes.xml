        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.UAS.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.UAS.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.UAS.LargeComponent</item>
